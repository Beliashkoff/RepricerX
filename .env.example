# Копируй в .env и заполняй
PORT=8080
ENVIRONMENT=dev

DATABASE_URL=postgres://admin:secret@localhost:5432/repricer_db?sslmode=disable
REDIS_ADDR=localhost:6379

# Минимум 32 случайных байта (openssl rand -base64 32)
APP_SECRET_KEY=

# Сессии
SESSION_IDLE_TTL=24h
SESSION_ABSOLUTE_TTL=168h

# CORS / CSRF
ALLOWED_ORIGINS=http://localhost:5173
TRUST_PROXY_HEADERS=false

# Почта: log — письма в stdout (для разработки), smtp — Яндекс.Почта
MAILER_MODE=log
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your-app@yandex.ru
# Используй пароль приложения (Почта → Безопасность → Пароли приложений)
SMTP_PASSWORD=
SMTP_FROM=AutoPrice <your-app@yandex.ru>
VERIFICATION_URL_BASE=http://localhost:5173/verify
